{
  "compilerOptions": {
    // ✔ Use TypeScript source from /src and output JS to /dist
    "rootDir": "./src",
    "outDir": "./dist",

    // ✔ ESM for Node.js
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    // ✔ Modern JS output
    "target": "ES2020",
    "lib": ["ES2020"],

    // ✔ Required for Node
    "types": ["node"],

    // ✔ Lets us write: import express from "express"
    "esModuleInterop": true,

    // ✔ Good TS defaults
    "strict": true,
    "skipLibCheck": true,

    // ✔ Allows debugging
    "sourceMap": true,

    // Optional but okay to keep
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src", "src/types"]
}
