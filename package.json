{
  "name": "expo-ecommerce",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint . --ext .js,.ts,.tsx,.jsx",
    "lint:fix": "eslint . --fix --ext .js,.ts,.tsx,.jsx",
    "lint:mobile": "eslint ./mobile  --ext .js,.ts,.tsx,.jsx",
    "lint:web": "eslint ./admin --ext .js,.ts,.tsx,.jsx",
    "lint:server": "eslint ./backend --ext .js,.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yaml.yml}": [
      "prettier --write"
    ]
  }
}
